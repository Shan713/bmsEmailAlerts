TASK: Book a movie ticket on BookMyShow by following these steps.

STEP 1: Go to https://in.bookmyshow.com

STEP 2: If a city/region popup appears, type "Coimbatore" in the city search box and click the matching city suggestion.

STEP 3: Click the search icon (magnifying glass), type "Gatta Kusthi 2", and click the correct movie from the search suggestions to open its page.

STEP 4: On the movie page, click the "Book tickets" button.

STEP 5: The page should show dates. Ensure the date "2026-07-06" (Monday, 06 July 2026) is selected. If it's not already selected, click it.

STEP 6: Scroll down to find the cinema "Broadway Cinemas". Look for its showtimes section.

STEP 7: Click the earliest showtime between 10:00 and 13:00 for "Broadway Cinemas". If no showtime in that exact window, pick the closest available one.

STEP 8: If a "Show Has Already Started" popup or any confirmation dialog appears, click "Continue" or "Yes" to proceed.

STEP 9: You are now on the seat selection page. Set the ticket quantity to 2. The page should say "How many seats?" — use the plus/minus buttons or a dropdown (with evaluate, NOT select_dropdown).

STEP 10: Click the "Select Seats" button.

STEP 11: Find and CLICK the accessibility mode button. This opens a modal that's much faster than the visual seat map. It's usually a small icon/button with a wheelchair symbol (♿) near the top of the seat area. If you truly cannot find it after 2 attempts, proceed with the visual seat map instead.

STEP 12: Inside the accessibility modal, use the evaluate tool to set ALL dropdowns with JavaScript. Run this entire block of code at once using evaluate:

```
// Set quantity dropdown
(function() {
    var qtySelect = document.querySelector('select[id*="quantity"], select[id*="ticket"], select[id*="qty"], select[name*="quantity"], select[name*="ticket"]');
    if (qtySelect) {
        var opts = Array.from(qtySelect.options);
        for (var i = 0; i < opts.length; i++) {
            if (opts[i].textContent.trim().startsWith('2')) {
                qtySelect.value = opts[i].value;
                break;
            }
        }
        qtySelect.dispatchEvent(new Event('change', { bubbles: true }));
        console.log('QUANTITY SET TO: ' + qtySelect.value);
    } else {
        console.log('QUANTITY SELECT NOT FOUND');
    }
})();

// Set category dropdown (try ELITE first)
(function() {
    var catSelect = document.querySelector('select[id*="category"], select[id*="cat"], select[name*="category"], select[name*="cat"]');
    if (catSelect) {
        var options = Array.from(catSelect.options).map(function(o) { return o.textContent.trim(); });
        console.log('CATEGORY OPTIONS:', options);
        var eliteIdx = options.findIndex(function(o) { return o.toUpperCase().includes('ELITE'); });
        var goldIdx = options.findIndex(function(o) { return o.toUpperCase().includes('GOLD') && !o.toUpperCase().includes('ELITE'); });
        var targetIdx = eliteIdx >= 0 ? eliteIdx : (goldIdx >= 0 ? goldIdx : Math.min(1, options.length - 1));
        catSelect.value = catSelect.options[targetIdx].value;
        catSelect.dispatchEvent(new Event('change', { bubbles: true }));
        console.log('CATEGORY SET TO: ' + options[targetIdx]);
    } else {
        console.log('CATEGORY SELECT NOT FOUND');
    }
})();

// Set row dropdown (middle of available rows)
(function() {
    var rowSelect = document.querySelector('select[id*="row"], select[name*="row"]');
    if (rowSelect) {
        var validOptions = Array.from(rowSelect.options).filter(function(o) { return o.value; });
        var midIndex = Math.floor(validOptions.length / 2);
        rowSelect.value = validOptions[midIndex].value;
        rowSelect.dispatchEvent(new Event('change', { bubbles: true }));
        console.log('ROW COUNT: ' + validOptions.length + ', PICKED INDEX: ' + midIndex + ', ROW: ' + validOptions[midIndex].textContent);
    } else {
        console.log('ROW SELECT NOT FOUND');
    }
})();
```

STEP 13: Now select 2 contiguous seats as close to CENTRE as possible. Use evaluate with this JavaScript:

```
