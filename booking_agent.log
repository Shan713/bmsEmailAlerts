    var available = seats.filter(function(s) {
        var label = s.getAttribute('aria-label') || '';
        return label.toLowerCase().includes('available') || (!label.toLowerCase().includes('unavailable') && !label.toLowerCase().includes('sold') && !label.toLowerCase().includes('booked'));
    });
    console.log('TOTAL SEAT BUTTONS: ' + seats.length + ', AVAILABLE: ' + available.length);

    var byRow = {};
    available.forEach(function(s) {
        var label = s.getAttribute('aria-label') || '';
        var rowMatch = label.match(/Row\s*([A-Za-z])/i);
        var row = rowMatch ? rowMatch[1].toUpperCase() : 'UNKNOWN';
        if (!byRow[row]) byRow[row] = [];
        byRow[row].push(s);
    });

    var rowKeys = Object.keys(byRow).sort();
    var midRow = rowKeys[Math.floor(rowKeys.length / 2)];
    console.log('ROWS: ' + rowKeys.join(',') + ', MIDDLE ROW: ' + midRow);

    if (byRow[midRow]) {
        var rowSeats = byRow[midRow];
        var midSeatIndex = Math.floor(rowSeats.length / 2);
        var startIdx = Math.max(0, midSeatIndex - Math.floor(2 / 2));
        var endIdx = Math.min(rowSeats.length, startIdx + 2);
        var selected = rowSeats.slice(startIdx, endIdx);
        console.log('SELECTING ' + selected.length + ' SEATS FROM INDEX ' + startIdx + ' TO ' + (endIdx - 1));
        selected.forEach(function(s) {
            console.log('CLICKING: ' + s.getAttribute('aria-label'));
            s.click();
        });
    } else {
        console.log('FALLBACK: clicking first 2 available seats');
        available.slice(0, 2).forEach(function(s) {
            console.log('CLICKING: ' + s.getAttribute('aria-label'));
            s.click();
        });
    }
})();
```

